{
  "name": "email-order-import",
  "version": "1.0.0",
  "description": "Gmail-to-ERP order import: search a Gmail inbox for messages lacking the 'imported' label that carry a PDF attachment, extract structured order data from each PDF with an LLM (structured outputs), validate it, create the order in the ERP via POST /orders/import, and label the message imported (or ignored, with a reason). Gmail is accessed through an MCP/HTTP-tool server; the PDF is uploaded to Supabase Storage and read by file_extract via a signed URL. Per-message outcomes are tracked in email_imports.",

  "input_schema": {
    "type": "object",
    "required": ["gmail_account"],
    "properties": {
      "gmail_account": { "type": "string", "minLength": 1, "description": "Mailbox to scan, e.g. orders@company.com." },
      "max_messages":  { "type": "number", "default": 20, "description": "Max unimported messages to process this run." }
    },
    "additionalProperties": false
  },

  "variables": {
    "gmail_search_url":        "http://gmail-mcp:8080/tools/search_pending",
    "gmail_download_url":      "http://gmail-mcp:8080/tools/download_attachment",
    "gmail_mark_imported_url": "http://gmail-mcp:8080/tools/mark_imported",
    "gmail_mark_ignored_url":  "http://gmail-mcp:8080/tools/mark_ignored",
    "orders_import_url":       "http://host.docker.internal:8090/orders/import"
  },

  "steps": {
    "sequence": {
      "steps": [

        {
          "activity": {
            "name": "http_request",
            "args": {
              "method": "POST",
              "url": "$var.gmail_search_url",
              "body": {
                "gmail_account": "$input.gmail_account",
                "label_exclude": "imported",
                "require_pdf": true,
                "max": "$input.max_messages"
              }
            },
            "result": "pending",
            "start_to_close_timeout": "30s",
            "retry": { "max_attempts": 3, "initial_interval": "2s" },
            "output_schema": {
              "type": "object",
              "required": ["messages"],
              "properties": {
                "messages": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["message_id", "has_pdf"],
                    "properties": {
                      "message_id": { "type": "string" },
                      "subject":    { "type": ["string", "null"] },
                      "has_pdf":    { "type": "boolean" }
                    }
                  }
                },
                "count": { "type": "number" }
              }
            }
          }
        },

        {
          "for_each": {
            "items": "$var.pending.messages",
            "item_var": "msg",
            "mode": "sequential",
            "body": {
              "try_catch": {
                "try": {
                  "sequence": {
                    "steps": [

                      {
                        "activity": {
                          "name": "http_request",
                          "args": {
                            "method": "POST",
                            "url": "$var.gmail_download_url",
                            "body": { "gmail_account": "$input.gmail_account", "message_id": "$var.msg.message_id" }
                          },
                          "result": "attachment",
                          "start_to_close_timeout": "60s",
                          "retry": { "max_attempts": 3, "initial_interval": "2s" },
                          "output_schema": {
                            "type": "object",
                            "required": ["has_pdf"],
                            "properties": {
                              "has_pdf":    { "type": "boolean" },
                              "filename":   { "type": ["string", "null"] },
                              "signed_url": { "type": ["string", "null"] }
                            }
                          }
                        }
                      },

                      {
                        "condition": {
                          "if": "$var.attachment.has_pdf == false",
                          "then": {
                            "sequence": {
                              "steps": [
                                {
                                  "activity": {
                                    "name": "http_request",
                                    "args": {
                                      "method": "POST",
                                      "url": "$var.gmail_mark_ignored_url",
                                      "body": { "gmail_account": "$input.gmail_account", "message_id": "$var.msg.message_id", "reason": "no PDF attachment" }
                                    },
                                    "result": "ignore_result",
                                    "start_to_close_timeout": "30s",
                                    "retry": { "max_attempts": 3 }
                                  }
                                },
                                {
                                  "activity": {
                                    "name": "supabase_mutate",
                                    "args": {
                                      "operation": "upsert",
                                      "table": "email_imports",
                                      "match": { "gmail_account": "$input.gmail_account", "message_id": "$var.msg.message_id" },
                                      "values": { "status": "ignored", "ignore_reason": "no PDF attachment" }
                                    },
                                    "result": "track_no_pdf",
                                    "start_to_close_timeout": "15s",
                                    "retry": { "max_attempts": 3 }
                                  }
                                }
                              ]
                            }
                          },
                          "else": {
                            "sequence": {
                              "steps": [

                                {
                                  "activity": {
                                    "name": "file_extract",
                                    "args": {
                                      "url": "$var.attachment.signed_url",
                                      "mime_type": "application/pdf",
                                      "extraction_schema": {
                                        "type": "object",
                                        "required": ["is_order"],
                                        "additionalProperties": false,
                                        "properties": {
                                          "is_order":      { "type": "boolean", "description": "false when the PDF is not a purchase order." },
                                          "ignore_reason": { "type": ["string", "null"], "description": "Why the document is not an importable order (set when is_order is false)." },
                                          "order": {
                                            "type": ["object", "null"],
                                            "required": ["customer", "lines"],
                                            "properties": {
                                              "customer": {
                                                "type": "object",
                                                "required": ["name"],
                                                "properties": {
                                                  "name":            { "type": "string", "minLength": 1 },
                                                  "document_number": { "type": ["string", "null"] },
                                                  "email":           { "type": ["string", "null"] },
                                                  "phone":           { "type": ["string", "null"] },
                                                  "address": {
                                                    "type": ["object", "null"],
                                                    "properties": {
                                                      "street":     { "type": ["string", "null"] },
                                                      "number":     { "type": ["string", "null"] },
                                                      "complement": { "type": ["string", "null"] },
                                                      "neighborhood": { "type": ["string", "null"] },
                                                      "city":       { "type": ["string", "null"] },
                                                      "state":      { "type": ["string", "null"] },
                                                      "postalCode": { "type": ["string", "null"] },
                                                      "country":    { "type": ["string", "null"] }
                                                    }
                                                  }
                                                }
                                              },
                                              "order_date": { "type": ["string", "null"], "description": "ISO 8601 date." },
                                              "lines": {
                                                "type": "array",
                                                "minItems": 1,
                                                "items": {
                                                  "type": "object",
                                                  "required": ["sku", "quantity"],
                                                  "properties": {
                                                    "sku":         { "type": "string" },
                                                    "description": { "type": ["string", "null"] },
                                                    "quantity":    { "type": "number", "minimum": 0 },
                                                    "unit_price":  { "type": ["number", "null"] },
                                                    "total":       { "type": ["number", "null"] }
                                                  }
                                                }
                                              }
                                            }
                                          }
                                        }
                                      }
                                    },
                                    "result": "extraction",
                                    "start_to_close_timeout": "120s",
                                    "retry": { "max_attempts": 2, "initial_interval": "3s" },
                                    "output_schema": {
                                      "type": "object",
                                      "required": ["extracted"],
                                      "properties": {
                                        "text": { "type": "string" },
                                        "extracted": {
                                          "type": "object",
                                          "required": ["is_order"],
                                          "properties": {
                                            "is_order":      { "type": "boolean" },
                                            "ignore_reason": { "type": ["string", "null"] },
                                            "order":         { "type": ["object", "null"] }
                                          }
                                        }
                                      }
                                    }
                                  }
                                },

                                {
                                  "condition": {
                                    "if": "$var.extraction.extracted.is_order == false",
                                    "then": {
                                      "sequence": {
                                        "steps": [
                                          {
                                            "activity": {
                                              "name": "http_request",
                                              "args": {
                                                "method": "POST",
                                                "url": "$var.gmail_mark_ignored_url",
                                                "body": { "gmail_account": "$input.gmail_account", "message_id": "$var.msg.message_id", "reason": "$var.extraction.extracted.ignore_reason" }
                                              },
                                              "result": "ignore_result",
                                              "start_to_close_timeout": "30s",
                                              "retry": { "max_attempts": 3 }
                                            }
                                          },
                                          {
                                            "activity": {
                                              "name": "supabase_mutate",
                                              "args": {
                                                "operation": "upsert",
                                                "table": "email_imports",
                                                "match": { "gmail_account": "$input.gmail_account", "message_id": "$var.msg.message_id" },
                                                "values": { "status": "ignored", "ignore_reason": "$var.extraction.extracted.ignore_reason" }
                                              },
                                              "result": "track_not_order",
                                              "start_to_close_timeout": "15s",
                                              "retry": { "max_attempts": 3 }
                                            }
                                          }
                                        ]
                                      }
                                    },
                                    "else": {
                                      "sequence": {
                                        "steps": [

                                          {
                                            "activity": {
                                              "name": "data_validate",
                                              "args": {
                                                "data": "$var.extraction.extracted.order",
                                                "rules": { "required_fields": ["customer", "lines"] },
                                                "throw_on_invalid": false
                                              },
                                              "result": "validated",
                                              "start_to_close_timeout": "10s",
                                              "retry": { "max_attempts": 1 },
                                              "output_schema": {
                                                "type": "object",
                                                "required": ["valid"],
                                                "properties": {
                                                  "valid":  { "type": "boolean" },
                                                  "errors": { "type": "array", "items": { "type": "string" } }
                                                }
                                              }
                                            }
                                          },

                                          {
                                            "condition": {
                                              "if": "$var.validated.valid == false",
                                              "then": {
                                                "sequence": {
                                                  "steps": [
                                                    {
                                                      "activity": {
                                                        "name": "http_request",
                                                        "args": {
                                                          "method": "POST",
                                                          "url": "$var.gmail_mark_ignored_url",
                                                          "body": { "gmail_account": "$input.gmail_account", "message_id": "$var.msg.message_id", "reason": "extracted order failed validation" }
                                                        },
                                                        "result": "ignore_result",
                                                        "start_to_close_timeout": "30s",
                                                        "retry": { "max_attempts": 3 }
                                                      }
                                                    },
                                                    {
                                                      "activity": {
                                                        "name": "supabase_mutate",
                                                        "args": {
                                                          "operation": "upsert",
                                                          "table": "email_imports",
                                                          "match": { "gmail_account": "$input.gmail_account", "message_id": "$var.msg.message_id" },
                                                          "values": { "status": "ignored", "ignore_reason": "extracted order failed validation" }
                                                        },
                                                        "result": "track_invalid",
                                                        "start_to_close_timeout": "15s",
                                                        "retry": { "max_attempts": 3 }
                                                      }
                                                    }
                                                  ]
                                                }
                                              },
                                              "else": {
                                                "sequence": {
                                                  "steps": [

                                                    {
                                                      "activity": {
                                                        "name": "http_request",
                                                        "args": {
                                                          "method": "POST",
                                                          "url": "$var.orders_import_url",
                                                          "body": "$var.extraction.extracted.order",
                                                          "expected_status": [200, 201],
                                                          "_idempotency_key": "order-import-$var.msg.message_id"
                                                        },
                                                        "result": "created_order",
                                                        "start_to_close_timeout": "30s",
                                                        "retry": { "max_attempts": 3, "initial_interval": "2s" }
                                                      }
                                                    },

                                                    {
                                                      "activity": {
                                                        "name": "http_request",
                                                        "args": {
                                                          "method": "POST",
                                                          "url": "$var.gmail_mark_imported_url",
                                                          "body": { "gmail_account": "$input.gmail_account", "message_id": "$var.msg.message_id" }
                                                        },
                                                        "result": "imported_result",
                                                        "start_to_close_timeout": "30s",
                                                        "retry": { "max_attempts": 3 }
                                                      }
                                                    },

                                                    {
                                                      "activity": {
                                                        "name": "supabase_mutate",
                                                        "args": {
                                                          "operation": "upsert",
                                                          "table": "email_imports",
                                                          "match": { "gmail_account": "$input.gmail_account", "message_id": "$var.msg.message_id" },
                                                          "values": { "status": "imported", "ignore_reason": null }
                                                        },
                                                        "result": "track_imported",
                                                        "start_to_close_timeout": "15s",
                                                        "retry": { "max_attempts": 3 }
                                                      }
                                                    }

                                                  ]
                                                }
                                              }
                                            }
                                          }

                                        ]
                                      }
                                    }
                                  }
                                }

                              ]
                            }
                          }
                        }
                      }

                    ]
                  }
                },
                "catch": {
                  "error_var": "msg_error",
                  "body": {
                    "activity": {
                      "name": "supabase_mutate",
                      "args": {
                        "operation": "upsert",
                        "table": "email_imports",
                        "match": { "gmail_account": "$input.gmail_account", "message_id": "$var.msg.message_id" },
                        "values": { "status": "error", "error_message": "$var.msg_error" }
                      },
                      "result": "track_error",
                      "start_to_close_timeout": "15s",
                      "retry": { "max_attempts": 3 }
                    }
                  }
                }
              }
            }
          }
        }

      ]
    }
  }
}
